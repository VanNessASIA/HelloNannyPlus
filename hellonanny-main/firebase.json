{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/submit-form",
        "function": "submitForm",
        "region": "asia-northeast1"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|jpg|jpeg|png|webp|ico|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "website",
      "runtime": "nodejs20"
    }
  ]
}
